# Application Environment
APP_NAME=self-medication-automation
APP_VERSION=2.0.0
DEBUG=False
ENVIRONMENT=production

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_SESSION_TOKEN=

# AWS Services
S3_BUCKET_NAME=self-medication-storage
DYNAMODB_TABLE=medication-records
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:medication-notifications
REKOGNITION_COLLECTION_ID=medication-images

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["*"]

# Model Configuration
MEDICATION_MODEL_PATH=models/medication_classifier.pkl
IMAGE_CONFIDENCE_THRESHOLD=0.85

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# API Keys
OPENAI_API_KEY=your-openai-api-key-if-needed
